# cedt_kr.rc is MBCS / CP949 (Korean codepage). Treat as binary so neither
# Git's CRLF normalization nor a careless re-save in an editor can rewrite
# it as UTF-8 — that loses every Korean menu/string in the file.
cedt_kr.rc -text

# Resource compiler outputs and other binary build inputs.
*.aps    binary
*.res    binary
*.ico    binary
*.bmp    binary
*.cur    binary

# Runtime assets shipped with the installer.
*.dic    binary
*.gif    binary
*.dll    binary
*.exe    binary

# spec / link / template files are CP949 (Korean comments / strings).
# Treat as non-text so the Korean bytes survive a round-trip through
# any editor that would otherwise re-save them as UTF-8.
runtime/spec/*.spc      -text
runtime/spec/*.key      -text
runtime/link/extension.*  -text
