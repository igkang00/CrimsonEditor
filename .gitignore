# Visual C++ 6.0 IDE caches
*.ncb
*.opt
*.plg
*.aps
*.dep

# Backups
*.bak

# Build output — each .vcxproj writes to its own $(ProjectDir)build/<Configuration>/
# (so the main project lands at /build/ and tests/cedt_tests.vcxproj at /tests/build/)
**/build/

# Installer build outputs: dist/redist/vc_redist.x86.exe (downloaded by
# build_installer.ps1) and dist/crimson-editor-*-setup.exe (ISCC output).
dist/

# Modern Visual Studio
.vs/
*.vcxproj.user

# vcpkg manifest-mode install dir
vcpkg_installed/

# Windows
Thumbs.db

# Personal AI-assistant instructions (kept locally, not shared)
CLAUDE.md
